/dts-v1/;
/ {
        compatible = "xlnx,versal-vck190-revA", "xlnx,versal";
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        model = "Xilinx Versal vck190 Eval board revA";

        options {

                u-boot {
                        compatible = "u-boot,config";
                        bootscr-address = /bits/ 64 <0x20000000>;
                };
        };

        cpus_a72: cpus {
                #address-cells = <0x1>;
                #size-cells = <0x0>;
                compatible = "cpus,cluster";
                #ranges-address-cells = <0x2>;
                #ranges-size-cells = <0x2>;
                address-map = <0x0 0x0 &memory0 0x0 0x0 0x0 0x80000000>,
                 <0x0 0xf0b20000 &fpd_funnelf0b20000 0x0 0xf0b20000 0x0 0x1000>,
                 <0x0 0xf0b30000 &fpd_etff0b30000 0x0 0xf0b30000 0x0 0x1000>,
                 <0x0 0xf0b40000 &replicatorf0b40000 0x0 0xf0b40000 0x0 0x1000>,
                 <0x0 0xf0b50000 &etrf0b50000 0x0 0xf0b50000 0x0 0x1000>,
                 <0x0 0xf0c20000 &funnelf0c20000 0x0 0xf0c20000 0x0 0x1000>,
                 <0x0 0xf0c30000 &etff0c30000 0x0 0xf0c30000 0x0 0x1000>,
                 <0x0 0xf0d00000 &cpu0_debugf0d00000 0x0 0xf0d00000 0x0 0x1000>,
                 <0x0 0xf0d30000 &etmf0d30000 0x0 0xf0d30000 0x0 0x1000>,
                 <0x0 0xf0d40000 &cpu1_debugf0d40000 0x0 0xf0d40000 0x0 0x1000>,
                 <0x0 0xf0d70000 &etmf0d70000 0x0 0xf0d70000 0x0 0x1000>,
                 <0x0 0xf1000000 &i2cf1000000 0x0 0xf1000000 0x0 0x1000>,
                 <0x0 0xf1010000 &spif1010000 0x0 0xf1010000 0x0 0x10000>,
                 <0x0 0xf1020000 &gpiof1020000 0x0 0xf1020000 0x0 0x1000>,
                 <0x0 0xf1030000 &spif1030000 0x0 0xf1030000 0x0 0x1000>,
                 <0x0 0xf1040000 &mmcf1040000 0x0 0xf1040000 0x0 0x10000>,
                 <0x0 0xf1050000 &mmcf1050000 0x0 0xf1050000 0x0 0x10000>,
                 <0x0 0xf1230000 &rngf1230000 0x0 0xf1230000 0x0 0x1000>,
                 <0x0 0xf1270000 &sysmonf1270000 0x0 0xf1270000 0x0 0x4000>,
                 <0x0 0xf12a0000 &rtcf12a0000 0x0 0xf12a0000 0x0 0x100>,
                 <0x0 0xf2014050 &edacf2014050 0x0 0xf2014050 0x0 0xc4>,
                 <0x0 0xf6150000 &memory_controllerf6150000 0x0 0xf6150000 0x0 0x2000>,
                 <0x0 0xf62c0000 &memory_controllerf62c0000 0x0 0xf62c0000 0x0 0x2000>,
                 <0x0 0xf6430000 &memory_controllerf6430000 0x0 0xf6430000 0x0 0x2000>,
                 <0x0 0xf65a0000 &memory_controllerf65a0000 0x0 0xf65a0000 0x0 0x2000>,
                 <0x0 0xf9000000 &interrupt_controllerf9000000 0x0 0xf9000000 0x0 0x80000>,
                 <0x0 0xf9020000 &msi_controllerf9020000 0x0 0xf9020000 0x0 0x20000>,
                 <0x0 0xfca10000 &pcifca10000 0x0 0xfca10000 0x0 0x1000>,
                 <0x0 0xfcdd0000 &pciefcdd0000 0x0 0xfcdd0000 0x0 0x1000>,
                 <0x0 0xfd000000 &ccifd000000 0x0 0xfd000000 0x0 0x10000>,
                 <0x0 0xfd4d0000 &watchdogfd4d0000 0x0 0xfd4d0000 0x0 0x10000>,
                 <0x0 0xfd800000 &iommufd800000 0x0 0xfd800000 0x0 0x40000>,
                 <0x0 0xfe200000 &usbfe200000 0x0 0xfe200000 0x0 0x10000>,
                 <0x0 0xff000000 &serialff000000 0x0 0xff000000 0x0 0x1000>,
                 <0x0 0xff010000 &serialff010000 0x0 0xff010000 0x0 0x1000>,
                 <0x0 0xff020000 &i2cff020000 0x0 0xff020000 0x0 0x1000>,
                 <0x0 0xff030000 &i2cff030000 0x0 0xff030000 0x0 0x1000>,
                 <0x0 0xff040000 &spiff040000 0x0 0xff040000 0x0 0x1000>,
                 <0x0 0xff050000 &spiff050000 0x0 0xff050000 0x0 0x1000>,
                 <0x0 0xff060000 &canff060000 0x0 0xff060000 0x0 0x6000>,
                 <0x0 0xff070000 &canff070000 0x0 0xff070000 0x0 0x6000>,
                 <0x0 0xff0b0000 &gpioff0b0000 0x0 0xff0b0000 0x0 0x1000>,
                 <0x0 0xff0c0000 &ethernetff0c0000 0x0 0xff0c0000 0x0 0x1000>,
                 <0x0 0xff0d0000 &ethernetff0d0000 0x0 0xff0d0000 0x0 0x1000>,
                 <0x0 0xff0e0000 &timerff0e0000 0x0 0xff0e0000 0x0 0x1000>,
                 <0x0 0xff0f0000 &timerff0f0000 0x0 0xff0f0000 0x0 0x1000>,
                 <0x0 0xff100000 &timerff100000 0x0 0xff100000 0x0 0x1000>,
                 <0x0 0xff110000 &timerff110000 0x0 0xff110000 0x0 0x1000>,
                 <0x0 0xff120000 &watchdogff120000 0x0 0xff120000 0x0 0x10000>,
                 <0x0 0xff3f0000 &mailboxff3f0000 0x0 0xff3f0000 0x0 0x10000>,
                 <0x0 0xff960000 &memory_controllerff960000 0x0 0xff960000 0x0 0x1000>,
                 <0x0 0xff9d0000 &usbff9d0000 0x0 0xff9d0000 0x0 0x100>,
                 <0x0 0xffa80000 &dma_controllerffa80000 0x0 0xffa80000 0x0 0x1000>,
                 <0x0 0xffa90000 &dma_controllerffa90000 0x0 0xffa90000 0x0 0x1000>,
                 <0x0 0xffaa0000 &dma_controllerffaa0000 0x0 0xffaa0000 0x0 0x1000>,
                 <0x0 0xffab0000 &dma_controllerffab0000 0x0 0xffab0000 0x0 0x1000>,
                 <0x0 0xffac0000 &dma_controllerffac0000 0x0 0xffac0000 0x0 0x1000>,
                 <0x0 0xffad0000 &dma_controllerffad0000 0x0 0xffad0000 0x0 0x1000>,
                 <0x0 0xffae0000 &dma_controllerffae0000 0x0 0xffae0000 0x0 0x1000>,
                 <0x0 0xffaf0000 &dma_controllerffaf0000 0x0 0xffaf0000 0x0 0x1000>,
                 <0x0 0xffe00000 &memoryffe00000 0x0 0xffe00000 0x0 0x10000>,
                 <0x0 0xffe20000 &memoryffe20000 0x0 0xffe20000 0x0 0x10000>,
                 <0x0 0xffe90000 &memoryffe90000 0x0 0xffe90000 0x0 0x10000>,
                 <0x0 0xffeb0000 &memoryffeb0000 0x0 0xffeb0000 0x0 0x10000>,
                 <0x0 0xfffc0000 &memoryfffc0000 0x0 0xfffc0000 0x0 0x40000>,
                 <0x1 0x9270000 &sysmon109270000 0x1 0x9270000 0x0 0x4000>,
                 <0x1 0x11270000 &sysmon111270000 0x1 0x11270000 0x0 0x4000>,
                 <0x1 0x19270000 &sysmon119270000 0x1 0x19270000 0x0 0x4000>;

                cpu0: cpu@0 {
                        phandle = <0x20>;
                        compatible = "arm,cortex-a72";
                        device_type = "cpu";
                        enable-method = "psci";
                        operating-points-v2 = <&opp_table_cpu>;
                        reg = <0x0>;
                        cpu-idle-states = <&cpu_sleep_0>;
                        d-cache-size = <0x8000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0xc000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_cache>;
                        clocks = <&clock_controller 0x4d>;
                };

                cpu1: cpu@1 {
                        phandle = <0x22>;
                        compatible = "arm,cortex-a72";
                        device_type = "cpu";
                        enable-method = "psci";
                        operating-points-v2 = <&opp_table_cpu>;
                        reg = <0x1>;
                        cpu-idle-states = <&cpu_sleep_0>;
                        d-cache-size = <0x8000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x100>;
                        i-cache-size = <0xc000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        next-level-cache = <&l2_cache>;
                };

                idle-states {
                        entry-method = "psci";

                        cpu_sleep_0: cpu-sleep-0 {
                                phandle = <0x2>;
                                compatible = "arm,idle-state";
                                arm,psci-suspend-param = <0x40000000>;
                                local-timer-stop;
                                entry-latency-us = <0x12c>;
                                exit-latency-us = <0x258>;
                                min-residency-us = <0x2710>;
                        };
                };
        };

        l2_cache: l2-cache {
                phandle = <0x3>;
                compatible = "cache";
                cache-level = <0x2>;
                cache-size = <0x100000>;
                cache-line-size = <0x40>;
                cache-sets = <0x1000>;
                cache-unified;
        };

        opp_table_cpu: opp-table-cpu {
                phandle = <0x1>;
                compatible = "operating-points-v2";
                opp-shared;

                opp00 {
                        opp-hz = /bits/ 64 <0x47868bf4>;
                        opp-microvolt = <0xf4240>;
                        clock-latency-ns = <0x7a120>;
                };

                opp01 {
                        opp-hz = /bits/ 64 <0x23c345fa>;
                        opp-microvolt = <0xf4240>;
                        clock-latency-ns = <0x7a120>;
                };

                opp02 {
                        opp-hz = /bits/ 64 <0x17d783fc>;
                        opp-microvolt = <0xf4240>;
                        clock-latency-ns = <0x7a120>;
                };

                opp03 {
                        opp-hz = /bits/ 64 <0x11e1a2fd>;
                        opp-microvolt = <0xf4240>;
                        clock-latency-ns = <0x7a120>;
                };
        };

        dcc {
                compatible = "arm,dcc";
                status = "okay";
                bootph-all;
        };

        fpga-region {
                compatible = "fpga-region";
                fpga-mgr = <&versal_fpga>;
                #address-cells = <0x2>;
                #size-cells = <0x2>;
        };

        psci {
                compatible = "arm,psci-0.2";
                method = "smc";
        };

        pmu {
                compatible = "arm,armv8-pmuv3";
                interrupt-parent = <&interrupt_controllerf9000000>;
                interrupts = <0x1 0x7 0x304>;
        };

        timer {
                compatible = "arm,armv8-timer";
                interrupt-parent = <&interrupt_controllerf9000000>;
                interrupts = <0x1 0xd 0x4 0x1 0xe 0x4 0x1 0xb 0x4 0x1 0xa 0x4>;
        };

        versal_fpga: versal-fpga {
                phandle = <0x5>;
                compatible = "xlnx,versal-fpga";
        };

        versal_thermal_sensor: versal-thermal-sensor {
                phandle = <0x8>;
                compatible = "xlnx,versal-thermal";
                #thermal-sensor-cells = <0x1>;
                io-channels = <&sysmonf1270000 0x0>;
                io-channel-names = "sysmon-temp-channel";
        };

        thermal-zones {

                versal-thermal {
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x3e8>;
                        thermal-sensors = <&versal_thermal_sensor 0x0>;

                        trips {

                                temp-alert {
                                        temperature = <0x11170>;
                                        hysteresis = <0x0>;
                                        type = "passive";
                                };

                                ot-crit {
                                        temperature = <0x1e848>;
                                        hysteresis = <0x0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {
                        };
                };

                versal-aie-thermal {
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x3e8>;
                        thermal-sensors = <&versal_thermal_sensor 0x1>;

                        trips {

                                temp-alert-aie {
                                        temperature = <0x11170>;
                                        hysteresis = <0x0>;
                                        type = "passive";
                                };

                                ot-crit-aie {
                                        temperature = <0x1e848>;
                                        hysteresis = <0x0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {
                        };
                };
        };

        axi {
                compatible = "simple-bus";
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;
                interrupt-parent = <&interrupt_controllerf9000000>;
                bootph-all;

                interrupt_controllerf9000000: interrupt-controller@f9000000 {
                        phandle = <0x6>;
                        compatible = "arm,gic-v3";
                        #interrupt-cells = <0x3>;
                        #address-cells = <0x2>;
                        #size-cells = <0x2>;
                        ranges;
                        reg = <0x0 0xf9000000 0x0 0x80000 0x0 0xf9080000 0x0 0x80000>;
                        interrupt-controller;
                        interrupts = <0x1 0x9 0x4>;

                        msi_controllerf9020000: msi-controller@f9020000 {
                                phandle = <0x12>;
                                compatible = "arm,gic-v3-its";
                                status = "disabled";
                                msi-controller;
                                #msi-cells = <0x1>;
                                reg = <0x0 0xf9020000 0x0 0x20000>;
                        };
                };

                canff060000: can@ff060000 {
                        phandle = <0x49>;
                        compatible = "xlnx,canfd-2.0";
                        status = "disabled";
                        reg = <0x0 0xff060000 0x0 0x6000>;
                        interrupts = <0x0 0x14 0x4>;
                        clock-names = "can_clk", "s_axi_aclk";
                        rx-fifo-depth = <0x40>;
                        tx-mailbox-count = <0x20>;
                        clocks = <&can0_clk>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x1822401f>;
                };

                canff070000: can@ff070000 {
                        phandle = <0x4a>;
                        compatible = "xlnx,canfd-2.0";
                        status = "okay";
                        reg = <0x0 0xff070000 0x0 0x6000>;
                        interrupts = <0x0 0x15 0x4>;
                        clock-names = "can_clk", "s_axi_aclk";
                        rx-fifo-depth = <0x40>;
                        tx-mailbox-count = <0x20>;
                        clocks = <&can1_clk>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224020>;
                };

                ccifd000000: cci@fd000000 {
                        phandle = <0x3f>;
                        compatible = "arm,cci-500";
                        status = "disabled";
                        reg = <0x0 0xfd000000 0x0 0x10000>;
                        ranges = <0x0 0x0 0xfd000000 0xa0000>;
                        #address-cells = <0x1>;
                        #size-cells = <0x1>;

                        pmu@10000 {
                                compatible = "arm,cci-500-pmu,r0";
                                reg = <0x10000 0x90000>;
                                interrupts = <0x0 0x6a 0x4 0x0 0x6a 0x4 0x0 0x6a 0x4 0x0 0x6a 0x4 0x0 0x6a 0x4 0x0 0x6a 0x4 0x0 0x6a 0x4 0x0 0x6a 0x4>;
                        };
                };

                dma_controllerffa80000: dma-controller@ffa80000 {
                        phandle = <0x56>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffa80000 0x0 0x1000>;
                        interrupts = <0x0 0x3c 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224035>;
                };

                dma_controllerffa90000: dma-controller@ffa90000 {
                        phandle = <0x57>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffa90000 0x0 0x1000>;
                        interrupts = <0x0 0x3d 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224036>;
                };

                dma_controllerffaa0000: dma-controller@ffaa0000 {
                        phandle = <0x58>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffaa0000 0x0 0x1000>;
                        interrupts = <0x0 0x3e 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224037>;
                };

                dma_controllerffab0000: dma-controller@ffab0000 {
                        phandle = <0x59>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffab0000 0x0 0x1000>;
                        interrupts = <0x0 0x3f 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224038>;
                };

                dma_controllerffac0000: dma-controller@ffac0000 {
                        phandle = <0x5a>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffac0000 0x0 0x1000>;
                        interrupts = <0x0 0x40 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224039>;
                };

                dma_controllerffad0000: dma-controller@ffad0000 {
                        phandle = <0x5b>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffad0000 0x0 0x1000>;
                        interrupts = <0x0 0x41 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x1822403a>;
                };

                dma_controllerffae0000: dma-controller@ffae0000 {
                        phandle = <0x5c>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffae0000 0x0 0x1000>;
                        interrupts = <0x0 0x42 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x1822403b>;
                };

                dma_controllerffaf0000: dma-controller@ffaf0000 {
                        phandle = <0x5d>;
                        compatible = "xlnx,zynqmp-dma-1.0";
                        status = "okay";
                        reg = <0x0 0xffaf0000 0x0 0x1000>;
                        interrupts = <0x0 0x43 0x4>;
                        clock-names = "clk_main", "clk_apb";
                        #dma-cells = <0x1>;
                        xlnx,bus-width = <0x40>;
                        clocks = <&clock_controller 0x51>,
                         <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x1822403c>;
                };

                ethernetff0c0000: ethernet@ff0c0000 {
                        phandle = <0x4c>;
                        compatible = "xlnx,versal-gem", "cdns,gem";
                        status = "okay";
                        reg = <0x0 0xff0c0000 0x0 0x1000>;
                        interrupts = <0x0 0x38 0x4 0x0 0x38 0x4>;
                        clock-names = "pclk", "hclk", "tx_clk", "rx_clk", "tsu_clk";
                        clocks = <&clock_controller 0x52>,
                         <&clock_controller 0x58>,
                         <&clock_controller 0x31>,
                         <&clock_controller 0x30>,
                         <&clock_controller 0x2b>;
                        power-domains = <&versal_firmware 0x18224019>;
                        phy-handle = <&ethernet_phy1>;
                        phy-mode = "rgmii-id";

                        mdio {
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;

                                ethernet_phy1: ethernet-phy@1 {
                                        phandle = <0xc>;
                                        #phy-cells = <0x1>;
                                        compatible = "ethernet-phy-id2000.a231";
                                        reg = <0x1>;
                                        ti,rx-internal-delay = <0xb>;
                                        ti,tx-internal-delay = <0xa>;
                                        ti,fifo-depth = <0x1>;
                                        ti,dp83867-rxctrl-strap-quirk;
                                        reset-assert-us = <0x64>;
                                        reset-deassert-us = <0x118>;
                                        reset-gpios = <&gpiof1020000 0x30 0x1>;
                                };

                                ethernet_phy2: ethernet-phy@2 {
                                        phandle = <0xe>;
                                        #phy-cells = <0x1>;
                                        compatible = "ethernet-phy-id2000.a231";
                                        reg = <0x2>;
                                        ti,rx-internal-delay = <0xb>;
                                        ti,tx-internal-delay = <0xa>;
                                        ti,fifo-depth = <0x1>;
                                        ti,dp83867-rxctrl-strap-quirk;
                                        reset-assert-us = <0x64>;
                                        reset-deassert-us = <0x118>;
                                        reset-gpios = <&gpiof1020000 0x31 0x1>;
                                };
                        };
                };

                ethernetff0d0000: ethernet@ff0d0000 {
                        phandle = <0x4d>;
                        compatible = "xlnx,versal-gem", "cdns,gem";
                        status = "okay";
                        reg = <0x0 0xff0d0000 0x0 0x1000>;
                        interrupts = <0x0 0x3a 0x4 0x0 0x3a 0x4>;
                        clock-names = "pclk", "hclk", "tx_clk", "rx_clk", "tsu_clk";
                        clocks = <&clock_controller 0x52>,
                         <&clock_controller 0x59>,
                         <&clock_controller 0x33>,
                         <&clock_controller 0x32>,
                         <&clock_controller 0x2b>;
                        power-domains = <&versal_firmware 0x1822401a>;
                        phy-handle = <&ethernet_phy2>;
                        phy-mode = "rgmii-id";
                };

                gpioff0b0000: gpio@ff0b0000 {
                        phandle = <0x4b>;
                        compatible = "xlnx,versal-gpio-1.0";
                        status = "okay";
                        reg = <0x0 0xff0b0000 0x0 0x1000>;
                        interrupts = <0x0 0xd 0x4>;
                        #gpio-cells = <0x2>;
                        gpio-controller;
                        #interrupt-cells = <0x2>;
                        interrupt-controller;
                        clocks = <&clock_controller 0x52>;
                        power-domains = <&versal_firmware 0x18224023>;
                };

                gpiof1020000: gpio@f1020000 {
                        phandle = <0xd>;
                        compatible = "xlnx,pmc-gpio-1.0";
                        status = "okay";
                        reg = <0x0 0xf1020000 0x0 0x1000>;
                        interrupts = <0x0 0x7a 0x4>;
                        #gpio-cells = <0x2>;
                        gpio-controller;
                        #interrupt-cells = <0x2>;
                        interrupt-controller;
                        clocks = <&clock_controller 0x3d>;
                        power-domains = <&versal_firmware 0x1822402c>;
                };

                i2cff020000: i2c@ff020000 {
                        phandle = <0x45>;
                        compatible = "cdns,i2c-r1p14";
                        status = "okay";
                        reg = <0x0 0xff020000 0x0 0x1000>;
                        interrupts = <0x0 0xe 0x4>;
                        clock-frequency = <0x186a0>;
                        #address-cells = <0x1>;
                        #size-cells = <0x0>;
