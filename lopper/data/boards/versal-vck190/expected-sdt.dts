        firmware {

                versal_firmware: versal-firmware {
                        phandle = <0xa>;
                        compatible = "xlnx,versal-firmware";
                        interrupt-parent = <&interrupt_controllerf9000000>;
                        bootph-all;
                        method = "smc";
                        #power-domain-cells = <0x1>;

                        clock_controller: clock-controller {
                                phandle = <0x4>;
                                bootph-all;
                                #clock-cells = <0x1>;
                                compatible = "xlnx,versal-clk";
                                clocks = <&ref>,
                                 <&pl_alt_ref>;
                                clock-names = "ref", "pl_alt_ref";
                        };

                        power-management {
                                compatible = "xlnx,zynqmp-power";
                        };

                        reset_controller: reset-controller {
                                phandle = <0x10>;
                                compatible = "xlnx,versal-reset";
                                #reset-cells = <0x1>;
                        };

                        pinctrl {
                                compatible = "xlnx,versal-pinctrl";
                        };

                        versal-sec-cfg {
                                compatible = "xlnx,versal-sec-cfg";

