                                                reg = <0x4 0x4>;
                                        };

                                        bbram-key@10 {
                                                reg = <0x10 0x20>;
                                        };

                                        bbram-usr@30 {
                                                reg = <0x30 0x4>;
                                        };

                                        bbram-lock@48 {
                                                reg = <0x48 0x4>;
                                        };

                                        user-key@110 {
                                                reg = <0x110 0x20>;
                                        };

                                        user-key@130 {
                                                reg = <0x130 0x20>;
                                        };

                                        user-key@150 {
                                                reg = <0x150 0x20>;
                                        };

                                        user-key@170 {
                                                reg = <0x170 0x20>;
                                        };

                                        user-key@190 {
                                                reg = <0x190 0x20>;
                                        };

                                        user-key@1b0 {
                                                reg = <0x1b0 0x20>;
                                        };

                                        user-key@1d0 {
                                                reg = <0x1d0 0x20>;
                                        };

                                        user-key@1f0 {
                                                reg = <0x1f0 0x20>;
                                        };
                                };
                        };
                };
        };

