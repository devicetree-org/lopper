/dts-v1/;
/ {
        interrupt-parent = <&interrupt_controller38800000>;
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        model = "FSL i.MX8MM EVK board";
        compatible = "fsl,imx8mm-evk", "fsl,imx8mm";

        aliases {
                ethernet0 = "/soc@0/bus@30800000/ethernet@30be0000";
                gpio0 = "/soc@0/bus@30000000/gpio@30200000";
                gpio1 = "/soc@0/bus@30000000/gpio@30210000";
                gpio2 = "/soc@0/bus@30000000/gpio@30220000";
                gpio3 = "/soc@0/bus@30000000/gpio@30230000";
                gpio4 = "/soc@0/bus@30000000/gpio@30240000";
                i2c0 = "/soc@0/bus@30800000/i2c@30a20000";
                i2c1 = "/soc@0/bus@30800000/i2c@30a30000";
                i2c2 = "/soc@0/bus@30800000/i2c@30a40000";
                i2c3 = "/soc@0/bus@30800000/i2c@30a50000";
                mmc0 = "/soc@0/bus@30800000/mmc@30b40000";
                mmc1 = "/soc@0/bus@30800000/mmc@30b50000";
                mmc2 = "/soc@0/bus@30800000/mmc@30b60000";
                serial0 = "/soc@0/bus@30800000/spba-bus@30800000/serial@30860000";
                serial1 = "/soc@0/bus@30800000/spba-bus@30800000/serial@30890000";
                serial2 = "/soc@0/bus@30800000/spba-bus@30800000/serial@30880000";
                serial3 = "/soc@0/bus@30800000/serial@30a60000";
                spi0 = "/soc@0/bus@30800000/spi@30bb0000";
                spi1 = "/soc@0/bus@30800000/spba-bus@30800000/spi@30830000";
                spi2 = "/soc@0/bus@30800000/spba-bus@30800000/spi@30840000";
        };

        cpus_a53: cpus {
                #address-cells = <0x1>;
                #size-cells = <0x0>;
                compatible = "cpus,cluster";

                idle-states {
                        entry-method = "psci";

                        cpu_pd_wait: cpu-pd-wait {
                                phandle = <0x6>;
                                compatible = "arm,idle-state";
                                arm,psci-suspend-param = <0x10033>;
                                local-timer-stop;
                                entry-latency-us = <0x3e8>;
                                exit-latency-us = <0x2bc>;
                                min-residency-us = <0xa8c>;
                        };
                };

                cpu0: cpu@0 {
                        phandle = <0xa>;
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x0>;
                        clocks = <&clock_controller30380000_1 0xd7>;
                        enable-method = "psci";
                        i-cache-size = <0x8000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        d-cache-size = <0x8000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x80>;
                        next-level-cache = <&l2_cache0>;
                        operating-points-v2 = <&opp_table>;
                        nvmem-cells = <&speed_grade10>;
                        nvmem-cell-names = "speed_grade";
                        cpu-idle-states = <&cpu_pd_wait>;
                        #cooling-cells = <0x2>;
                        cpu-supply = <&BUCK2>;
                };

                cpu1: cpu@1 {
                        phandle = <0xb>;
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x1>;
                        clocks = <&clock_controller30380000_1 0xd7>;
                        enable-method = "psci";
                        i-cache-size = <0x8000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        d-cache-size = <0x8000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x80>;
                        next-level-cache = <&l2_cache0>;
                        operating-points-v2 = <&opp_table>;
                        cpu-idle-states = <&cpu_pd_wait>;
                        #cooling-cells = <0x2>;
                        cpu-supply = <&BUCK2>;
                };

                cpu2: cpu@2 {
                        phandle = <0xc>;
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x2>;
                        clocks = <&clock_controller30380000_1 0xd7>;
                        enable-method = "psci";
                        i-cache-size = <0x8000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        d-cache-size = <0x8000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x80>;
                        next-level-cache = <&l2_cache0>;
                        operating-points-v2 = <&opp_table>;
                        cpu-idle-states = <&cpu_pd_wait>;
                        #cooling-cells = <0x2>;
                        cpu-supply = <&BUCK2>;
                };

                cpu3: cpu@3 {
                        phandle = <0xd>;
                        device_type = "cpu";
                        compatible = "arm,cortex-a53";
                        reg = <0x3>;
                        clocks = <&clock_controller30380000_1 0xd7>;
                        enable-method = "psci";
                        i-cache-size = <0x8000>;
                        i-cache-line-size = <0x40>;
                        i-cache-sets = <0x100>;
                        d-cache-size = <0x8000>;
                        d-cache-line-size = <0x40>;
                        d-cache-sets = <0x80>;
                        next-level-cache = <&l2_cache0>;
                        operating-points-v2 = <&opp_table>;
                        cpu-idle-states = <&cpu_pd_wait>;
                        #cooling-cells = <0x2>;
                        cpu-supply = <&BUCK2>;
                };

                l2_cache0: l2-cache0 {
                        phandle = <0x3>;
                        compatible = "cache";
                        cache-level = <0x2>;
                        cache-unified;
                        cache-size = <0x80000>;
                        cache-line-size = <0x40>;
                        cache-sets = <0x200>;
                };
        };

        opp_table: opp-table {
                phandle = <0x4>;
                compatible = "operating-points-v2";
                opp-shared;

                opp-1200000000 {
                        opp-hz = /bits/ 64 <0x47868c00>;
                        opp-microvolt = <0xcf850>;
                        opp-supported-hw = <0xe 0x7>;
                        clock-latency-ns = <0x249f0>;
                        opp-suspend;
                };

                opp-1600000000 {
                        opp-hz = /bits/ 64 <0x5f5e1000>;
                        opp-microvolt = <0xe7ef0>;
                        opp-supported-hw = <0xc 0x7>;
                        clock-latency-ns = <0x249f0>;
                        opp-suspend;
                };

                opp-1800000000 {
                        opp-hz = /bits/ 64 <0x6b49d200>;
                        opp-microvolt = <0xf4240>;
                        opp-supported-hw = <0x8 0x3>;
                        clock-latency-ns = <0x249f0>;
                        opp-suspend;
                };
        };

        clock_osc_32k: clock-osc-32k {
                phandle = <0x1a>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x8000>;
                clock-output-names = "osc_32k";
        };

        clock_osc_24m: clock-osc-24m {
                phandle = <0x1b>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x16e3600>;
                clock-output-names = "osc_24m";
        };

        clock_ext1: clock-ext1 {
                phandle = <0x1c>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext1";
        };

        clock_ext2: clock-ext2 {
                phandle = <0x1d>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext2";
        };

        clock_ext3: clock-ext3 {
                phandle = <0x1e>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext3";
        };

        clock_ext4: clock-ext4 {
                phandle = <0x1f>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x7ed6b40>;
                clock-output-names = "clk_ext4";
        };

        psci {
                compatible = "arm,psci-1.0";
                method = "smc";
        };

        pmu {
                compatible = "arm,cortex-a53-pmu";
                interrupts = <0x1 0x7 0x4>;
        };

        timer {
                compatible = "arm,armv8-timer";
                interrupts = <0x1 0xd 0x8 0x1 0xe 0x8 0x1 0xb 0x8 0x1 0xa 0x8>;
                clock-frequency = <0x7a1200>;
                arm,no-tick-in-suspend;
        };

        thermal-zones {

                cpu-thermal {
                        polling-delay-passive = <0xfa>;
                        polling-delay = <0x7d0>;
                        thermal-sensors = <&tmu30260000>;

                        trips {

                                trip0: trip0 {
                                        phandle = <0x9>;
                                        temperature = <0x14c08>;
                                        hysteresis = <0x7d0>;
                                        type = "passive";
                                };

                                trip1 {
                                        temperature = <0x17318>;
                                        hysteresis = <0x7d0>;
                                        type = "critical";
                                };
                        };

                        cooling-maps {

                                map0 {
                                        trip = <&trip0>;
                                        cooling-device = <&cpu0 0xffffffff 0xffffffff>,
                                         <&cpu1 0xffffffff 0xffffffff>,
                                         <&cpu2 0xffffffff 0xffffffff>,
                                         <&cpu3 0xffffffff 0xffffffff>;
                                };
                        };
                };
        };

        usbphynop1: usbphynop1 {
                phandle = <0x51>;
                #phy-cells = <0x0>;
                compatible = "usb-nop-xceiv";
                clocks = <&clock_controller30380000_1 0x84>;
                assigned-clocks = <&clock_controller30380000_1 0x84>;
                assigned-clock-parents = <&clock_controller30380000_1 0x32>;
                clock-names = "main_clk";
                power-domains = <&power_domain2>;
                wakeup-source;
        };

        usbphynop2: usbphynop2 {
                phandle = <0x54>;
                #phy-cells = <0x0>;
                compatible = "usb-nop-xceiv";
                clocks = <&clock_controller30380000_1 0x84>;
                assigned-clocks = <&clock_controller30380000_1 0x84>;
                assigned-clock-parents = <&clock_controller30380000_1 0x32>;
                clock-names = "main_clk";
                power-domains = <&power_domain3>;
        };

        soc@0 {
                compatible = "fsl,imx8mm-soc", "simple-bus";
                #address-cells = <0x1>;
                #size-cells = <0x1>;
                ranges = <0x0 0x0 0x0 0x3e000000>;
                dma-ranges = <0x40000000 0x0 0x40000000 0xc0000000>;
                nvmem-cells = <&unique_id4>;
                nvmem-cell-names = "soc_unique_id";

                bus@30000000 {
                        compatible = "fsl,aips-bus", "simple-bus";
                        reg = <0x30000000 0x400000>;
                        #address-cells = <0x1>;
                        #size-cells = <0x1>;
                        ranges = <0x30000000 0x30000000 0x400000>;

                        spba-bus@30000000 {
                                compatible = "fsl,spba-bus", "simple-bus";
                                #address-cells = <0x1>;
                                #size-cells = <0x1>;
                                reg = <0x30000000 0x100000>;
                                ranges;

                                sai@30010000 {
                                        #sound-dai-cells = <0x0>;
                                        compatible = "fsl,imx8mm-sai", "fsl,imx8mq-sai";
                                        reg = <0x30010000 0x10000>;
                                        interrupts = <0x0 0x5f 0x4>;
                                        clocks = <&clock_controller30380000_1 0xb1>,
                                         <&clock_controller30380000_1 0xb0>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>;
                                        clock-names = "bus", "mclk1", "mclk2", "mclk3";
                                        dmas = <&dma_controller302c0000 0x0 0x2 0x0>,
                                         <&dma_controller302c0000 0x1 0x2 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "disabled";
                                };

                                sai30020000: sai@30020000 {
                                        phandle = <0x6d>;
                                        #sound-dai-cells = <0x0>;
                                        compatible = "fsl,imx8mm-sai", "fsl,imx8mq-sai";
                                        reg = <0x30020000 0x10000>;
                                        interrupts = <0x0 0x60 0x4>;
                                        clocks = <&clock_controller30380000_1 0xb3>,
                                         <&clock_controller30380000_1 0xb2>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>;
                                        clock-names = "bus", "mclk1", "mclk2", "mclk3";
                                        dmas = <&dma_controller302c0000 0x2 0x2 0x0>,
                                         <&dma_controller302c0000 0x3 0x2 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&sai2grp>;
                                        assigned-clocks = <&clock_controller30380000_1 0x6d>;
                                        assigned-clock-parents = <&clock_controller30380000_1 0x26>;
                                        assigned-clock-rates = <0x1770000>;
                                };

                                sai30030000: sai@30030000 {
                                        phandle = <0x70>;
                                        #sound-dai-cells = <0x0>;
                                        compatible = "fsl,imx8mm-sai", "fsl,imx8mq-sai";
                                        reg = <0x30030000 0x10000>;
                                        interrupts = <0x0 0x32 0x4>;
                                        clocks = <&clock_controller30380000_1 0xb5>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0xb4>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x26>,
                                         <&clock_controller30380000_1 0x27>;
                                        clock-names = "bus", "mclk0", "mclk1", "mclk2", "mclk3", "pll8k", "pll11k";
                                        dmas = <&dma_controller302c0000 0x4 0x2 0x0>,
                                         <&dma_controller302c0000 0x5 0x2 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&sai3grp>;
                                        assigned-clocks = <&clock_controller30380000_1 0x12>,
                                         <&clock_controller30380000_1 0x13>,
                                         <&clock_controller30380000_1 0x6e>;
                                        assigned-clock-parents = <0x0 0x0>,
                                         <&clock_controller30380000_1 0x26>;
                                        assigned-clock-rates = <0x17700000 0x15888000 0x1770000>;
                                        fsl,sai-mclk-direction-output;
                                };

                                sai@30050000 {
                                        #sound-dai-cells = <0x0>;
                                        compatible = "fsl,imx8mm-sai", "fsl,imx8mq-sai";
                                        reg = <0x30050000 0x10000>;
                                        interrupts = <0x0 0x5a 0x4>;
                                        clocks = <&clock_controller30380000_1 0xb9>,
                                         <&clock_controller30380000_1 0xb8>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>;
                                        clock-names = "bus", "mclk1", "mclk2", "mclk3";
                                        dmas = <&dma_controller302c0000 0x8 0x2 0x0>,
                                         <&dma_controller302c0000 0x9 0x2 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "disabled";
                                };

                                sai@30060000 {
                                        #sound-dai-cells = <0x0>;
                                        compatible = "fsl,imx8mm-sai", "fsl,imx8mq-sai";
                                        reg = <0x30060000 0x10000>;
                                        interrupts = <0x0 0x5a 0x4>;
                                        clocks = <&clock_controller30380000_1 0xbb>,
                                         <&clock_controller30380000_1 0xba>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>;
                                        clock-names = "bus", "mclk1", "mclk2", "mclk3";
                                        dmas = <&dma_controller302c0000 0xa 0x2 0x0>,
                                         <&dma_controller302c0000 0xb 0x2 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "disabled";
                                };

                                audio_controller30080000: audio-controller@30080000 {
                                        phandle = <0x72>;
                                        compatible = "fsl,imx8mm-micfil";
                                        reg = <0x30080000 0x10000>;
                                        interrupts = <0x0 0x6d 0x4 0x0 0x6e 0x4 0x0 0x2c 0x4 0x0 0x2d 0x4>;
                                        clocks = <&clock_controller30380000_1 0xd8>,
                                         <&clock_controller30380000_1 0xcb>,
                                         <&clock_controller30380000_1 0x26>,
                                         <&clock_controller30380000_1 0x27>,
                                         <&clock_controller30380000_1 0x6>;
                                        clock-names = "ipg_clk", "ipg_clk_app", "pll8k", "pll11k", "clkext3";
                                        dmas = <&dma_controller302c0000 0x18 0x19 0x80000000>;
                                        dma-names = "rx";
                                        #sound-dai-cells = <0x0>;
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&pdmgrp>;
                                        assigned-clocks = <&clock_controller30380000_1 0x9c>;
                                        assigned-clock-parents = <&clock_controller30380000_1 0x26>;
                                        assigned-clock-rates = <0xbb80000>;
                                };

                                spdif30090000: spdif@30090000 {
                                        phandle = <0x73>;
                                        compatible = "fsl,imx8mm-spdif";
                                        reg = <0x30090000 0x10000>;
                                        interrupts = <0x0 0x6 0x4>;
                                        clocks = <&clock_controller30380000_1 0x5e>,
                                         <&clock_controller30380000_1 0x2>,
                                         <&clock_controller30380000_1 0x72>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x5e>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x0>,
                                         <&clock_controller30380000_1 0x26>,
                                         <&clock_controller30380000_1 0x27>;
                                        clock-names = "core", "rxtx0", "rxtx1", "rxtx2", "rxtx3", "rxtx4", "rxtx5", "rxtx6", "rxtx7", "spba", "pll8k", "pll11k";
                                        dmas = <&dma_controller302c0000 0x1c 0x12 0x0>,
                                         <&dma_controller302c0000 0x1d 0x12 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&spdif1grp>;
                                        assigned-clocks = <&clock_controller30380000_1 0x72>;
                                        assigned-clock-parents = <&clock_controller30380000_1 0x26>;
                                        assigned-clock-rates = <0x1770000>;
                                };
                        };

                        gpio30200000: gpio@30200000 {
                                phandle = <0x2a>;
                                compatible = "fsl,imx8mm-gpio", "fsl,imx35-gpio";
                                reg = <0x30200000 0x10000>;
                                interrupts = <0x0 0x40 0x4 0x0 0x41 0x4>;
                                clocks = <&clock_controller30380000_1 0xdf>;
                                gpio-controller;
                                #gpio-cells = <0x2>;
                                interrupt-controller;
                                #interrupt-cells = <0x2>;
                                gpio-ranges = <&pinctrl30330000 0x0 0xa 0x1e>;
                        };

                        gpio30210000: gpio@30210000 {
                                phandle = <0x31>;
                                compatible = "fsl,imx8mm-gpio", "fsl,imx35-gpio";
                                reg = <0x30210000 0x10000>;
                                interrupts = <0x0 0x42 0x4 0x0 0x43 0x4>;
                                clocks = <&clock_controller30380000_1 0xe0>;
                                gpio-controller;
                                #gpio-cells = <0x2>;
                                interrupt-controller;
                                #interrupt-cells = <0x2>;
                                gpio-ranges = <&pinctrl30330000 0x0 0x28 0x15>;
                        };

                        gpio30220000: gpio@30220000 {
                                phandle = <0x65>;
                                compatible = "fsl,imx8mm-gpio", "fsl,imx35-gpio";
                                reg = <0x30220000 0x10000>;
                                interrupts = <0x0 0x44 0x4 0x0 0x45 0x4>;
                                clocks = <&clock_controller30380000_1 0xe1>;
                                gpio-controller;
                                #gpio-cells = <0x2>;
                                interrupt-controller;
                                #interrupt-cells = <0x2>;
                                gpio-ranges = <&pinctrl30330000 0x0 0x3d 0x1a>;
                        };

                        gpio30230000: gpio@30230000 {
                                phandle = <0x46>;
                                compatible = "fsl,imx8mm-gpio", "fsl,imx35-gpio";
                                reg = <0x30230000 0x10000>;
                                interrupts = <0x0 0x46 0x4 0x0 0x47 0x4>;
                                clocks = <&clock_controller30380000_1 0xe2>;
                                gpio-controller;
                                #gpio-cells = <0x2>;
                                interrupt-controller;
                                #interrupt-cells = <0x2>;
                                gpio-ranges = <&pinctrl30330000 0x0 0x57 0x20>;
                        };

                        gpio@30240000 {
                                phandle = <0x6b>;
                                compatible = "fsl,imx8mm-gpio", "fsl,imx35-gpio";
                                reg = <0x30240000 0x10000>;
                                interrupts = <0x0 0x48 0x4 0x0 0x49 0x4>;
                                clocks = <&clock_controller30380000_1 0xe3>;
                                gpio-controller;
                                #gpio-cells = <0x2>;
                                interrupt-controller;
                                #interrupt-cells = <0x2>;
                                gpio-ranges = <&pinctrl30330000 0x0 0x77 0x1e>;
                        };

                        tmu30260000: tmu@30260000 {
                                phandle = <0x8>;
                                compatible = "fsl,imx8mm-tmu";
                                reg = <0x30260000 0x10000>;
                                clocks = <&clock_controller30380000_1 0xd1>;
                                nvmem-cells = <&calib3c>;
                                nvmem-cell-names = "calib";
                                #thermal-sensor-cells = <0x0>;
                        };

                        watchdog@30280000 {
                                compatible = "fsl,imx8mm-wdt", "fsl,imx21-wdt";
                                reg = <0x30280000 0x10000>;
                                interrupts = <0x0 0x4e 0x4>;
                                clocks = <&clock_controller30380000_1 0xc4>;
                                status = "okay";
                                pinctrl-names = "default";
                                pinctrl-0 = <&wdoggrp>;
                                fsl,ext-reset-output;
                        };

                        watchdog@30290000 {
                                compatible = "fsl,imx8mm-wdt", "fsl,imx21-wdt";
                                reg = <0x30290000 0x10000>;
                                interrupts = <0x0 0x4f 0x4>;
                                clocks = <&clock_controller30380000_1 0xc5>;
                                status = "disabled";
                        };

                        watchdog@302a0000 {
                                compatible = "fsl,imx8mm-wdt", "fsl,imx21-wdt";
                                reg = <0x302a0000 0x10000>;
                                interrupts = <0x0 0xa 0x4>;
                                clocks = <&clock_controller30380000_1 0xc6>;
                                status = "disabled";
                        };

                        dma_controller302c0000: dma-controller@302c0000 {
                                phandle = <0x11>;
                                compatible = "fsl,imx8mm-sdma", "fsl,imx8mq-sdma";
                                reg = <0x302c0000 0x10000>;
                                interrupts = <0x0 0x67 0x4>;
                                clocks = <&clock_controller30380000_1 0xd4>,
                                 <&clock_controller30380000_1 0xd4>;
                                clock-names = <0x69706700 0x61686200>;
