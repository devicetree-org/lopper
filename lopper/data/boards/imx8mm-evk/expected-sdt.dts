                                reg = <0x30800000 0x100000>;
                                ranges;

                                spi@30820000 {
                                        compatible = "fsl,imx8mm-ecspi", "fsl,imx51-ecspi";
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x30820000 0x10000>;
                                        interrupts = <0x0 0x1f 0x4>;
                                        clocks = <&clock_controller30380000_1 0x9f>,
                                         <&clock_controller30380000_1 0x9f>;
                                        clock-names = <0x69706700 0x70657200>;
                                        dmas = <&dma_controller30bd0000 0x0 0x7 0x1>,
                                         <&dma_controller30bd0000 0x1 0x7 0x2>;
                                        dma-names = "rx", "tx";
                                        status = "disabled";
                                };

                                spi@30830000 {
                                        compatible = "fsl,imx8mm-ecspi", "fsl,imx51-ecspi";
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x30830000 0x10000>;
                                        interrupts = <0x0 0x20 0x4>;
                                        clocks = <&clock_controller30380000_1 0xa0>,
                                         <&clock_controller30380000_1 0xa0>;
                                        clock-names = <0x69706700 0x70657200>;
                                        dmas = <&dma_controller30bd0000 0x2 0x7 0x1>,
                                         <&dma_controller30bd0000 0x3 0x7 0x2>;
                                        dma-names = "rx", "tx";
                                        status = "disabled";
                                };

                                spi@30840000 {
                                        compatible = "fsl,imx8mm-ecspi", "fsl,imx51-ecspi";
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;
                                        reg = <0x30840000 0x10000>;
                                        interrupts = <0x0 0x21 0x4>;
                                        clocks = <&clock_controller30380000_1 0xa1>,
                                         <&clock_controller30380000_1 0xa1>;
                                        clock-names = <0x69706700 0x70657200>;
                                        dmas = <&dma_controller30bd0000 0x4 0x7 0x1>,
                                         <&dma_controller30bd0000 0x5 0x7 0x2>;
                                        dma-names = "rx", "tx";
                                        status = "disabled";
                                };

                                serial@30860000 {
                                        compatible = "fsl,imx8mm-uart", "fsl,imx6q-uart";
                                        reg = <0x30860000 0x10000>;
                                        interrupts = <0x0 0x1a 0x4>;
                                        clocks = <&clock_controller30380000_1 0xbc>,
                                         <&clock_controller30380000_1 0xbc>;
                                        clock-names = <0x69706700 0x70657200>;
                                        dmas = <&dma_controller30bd0000 0x16 0x4 0x0>,
                                         <&dma_controller30bd0000 0x17 0x4 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&uart1grp>;
                                        assigned-clocks = <&clock_controller30380000_1 0x7f>;
                                        assigned-clock-parents = <&clock_controller30380000_1 0x31>;
                                        uart-has-rtscts;

                                        bluetooth {
                                                compatible = "nxp,88w8987-bt";
                                        };
                                };

                                serial@30880000 {
                                        compatible = "fsl,imx8mm-uart", "fsl,imx6q-uart";
                                        reg = <0x30880000 0x10000>;
                                        interrupts = <0x0 0x1c 0x4>;
                                        clocks = <&clock_controller30380000_1 0xbe>,
                                         <&clock_controller30380000_1 0xbe>;
                                        clock-names = <0x69706700 0x70657200>;
                                        dmas = <&dma_controller30bd0000 0x1a 0x4 0x0>,
                                         <&dma_controller30bd0000 0x1b 0x4 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&uart3grp>;
                                        assigned-clocks = <&clock_controller30380000_1 0x81>;
                                        assigned-clock-parents = <&clock_controller30380000_1 0x31>;
                                        uart-has-rtscts;
                                };

                                serial@30890000 {
                                        compatible = "fsl,imx8mm-uart", "fsl,imx6q-uart";
                                        reg = <0x30890000 0x10000>;
                                        interrupts = <0x0 0x1b 0x4>;
                                        clocks = <&clock_controller30380000_1 0xbd>,
                                         <&clock_controller30380000_1 0xbd>;
                                        clock-names = <0x69706700 0x70657200>;
                                        dmas = <&dma_controller30bd0000 0x18 0x4 0x0>,
                                         <&dma_controller30bd0000 0x19 0x4 0x0>;
                                        dma-names = "rx", "tx";
                                        status = "okay";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&uart2grp>;
                                };
                        };

                        crypto@30900000 {
                                compatible = "fsl,sec-v4.0";
                                #address-cells = <0x1>;
                                #size-cells = <0x1>;
                                reg = <0x30900000 0x40000>;
                                ranges = <0x0 0x30900000 0x40000>;
                                interrupts = <0x0 0x5b 0x4>;
                                clocks = <&clock_controller30380000_1 0x5d>,
                                 <&clock_controller30380000_1 0x5f>;
                                clock-names = "aclk", "ipg";

                                jr@1000 {
                                        compatible = "fsl,sec-v4.0-job-ring";
                                        reg = <0x1000 0x1000>;
                                        interrupts = <0x0 0x69 0x4>;
                                        status = "disabled";
                                };

                                jr@2000 {
                                        compatible = "fsl,sec-v4.0-job-ring";
                                        reg = <0x2000 0x1000>;
                                        interrupts = <0x0 0x6a 0x4>;
                                };

                                jr@3000 {
                                        compatible = "fsl,sec-v4.0-job-ring";
                                        reg = <0x3000 0x1000>;
                                        interrupts = <0x0 0x72 0x4>;
                                };
                        };

                        i2c@30a20000 {
                                compatible = "fsl,imx8mm-i2c", "fsl,imx21-i2c";
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;
                                reg = <0x30a20000 0x10000>;
                                interrupts = <0x0 0x23 0x4>;
                                clocks = <&clock_controller30380000_1 0xa4>;
                                status = "okay";
                                clock-frequency = <0x61a80>;
                                pinctrl-names = "default";
                                pinctrl-0 = <&i2c1grp>;

                                pmic@4b {
                                        compatible = "rohm,bd71847";
                                        reg = <0x4b>;
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&pmicirqgrp>;
                                        interrupt-parent = <&gpio30200000>;
                                        interrupts = <0x3 0x8>;
                                        rohm,reset-snvs-powered;
                                        #clock-cells = <0x0>;
                                        clocks = <&clock_osc_32k>;
                                        clock-output-names = "clk-32k-out";

                                        regulators {

                                                BUCK1 {
                                                        regulator-name = "buck1";
                                                        regulator-min-microvolt = <0xaae60>;
                                                        regulator-max-microvolt = <0x13d620>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                        regulator-ramp-delay = <0x4e2>;
                                                };

                                                BUCK2: BUCK2 {
                                                        phandle = <0x7>;
                                                        regulator-name = "buck2";
                                                        regulator-min-microvolt = <0xaae60>;
                                                        regulator-max-microvolt = <0x13d620>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                        regulator-ramp-delay = <0x4e2>;
                                                        rohm,dvs-run-voltage = <0xf4240>;
                                                        rohm,dvs-idle-voltage = <0xdbba0>;
                                                };

                                                BUCK3 {
                                                        regulator-name = "buck3";
                                                        regulator-min-microvolt = <0xaae60>;
                                                        regulator-max-microvolt = <0x149970>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                BUCK4: BUCK4 {
                                                        phandle = <0x34>;
                                                        regulator-name = "buck4";
                                                        regulator-min-microvolt = <0x2dc6c0>;
                                                        regulator-max-microvolt = <0x325aa0>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                BUCK5: BUCK5 {
                                                        phandle = <0x2c>;
                                                        regulator-name = "buck5";
                                                        regulator-min-microvolt = <0x187d88>;
                                                        regulator-max-microvolt = <0x1e70f8>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                BUCK6 {
                                                        regulator-name = "buck6";
                                                        regulator-min-microvolt = <0xc3500>;
                                                        regulator-max-microvolt = <0x155cc0>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                LDO1 {
                                                        regulator-name = "ldo1";
                                                        regulator-min-microvolt = <0x186a00>;
                                                        regulator-max-microvolt = <0x325aa0>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                LDO2 {
                                                        regulator-name = "ldo2";
                                                        regulator-min-microvolt = <0xc3500>;
                                                        regulator-max-microvolt = <0xdbba0>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                LDO3 {
                                                        regulator-name = "ldo3";
                                                        regulator-min-microvolt = <0x1b7740>;
                                                        regulator-max-microvolt = <0x325aa0>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                LDO4 {
                                                        regulator-name = "ldo4";
                                                        regulator-min-microvolt = <0xdbba0>;
                                                        regulator-max-microvolt = <0x1b7740>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };

                                                LDO6 {
                                                        regulator-name = "ldo6";
                                                        regulator-min-microvolt = <0xdbba0>;
                                                        regulator-max-microvolt = <0x1b7740>;
                                                        regulator-boot-on;
                                                        regulator-always-on;
                                                };
                                        };
                                };
                        };

                        i2c@30a30000 {
                                compatible = "fsl,imx8mm-i2c", "fsl,imx21-i2c";
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;
                                reg = <0x30a30000 0x10000>;
                                interrupts = <0x0 0x24 0x4>;
                                clocks = <&clock_controller30380000_1 0xa5>;
                                status = "okay";
                                clock-frequency = <0x61a80>;
                                pinctrl-names = "default";
                                pinctrl-0 = <&i2c2grp>;

                                hdmi@3d {
                                        compatible = "adi,adv7535";
                                        reg = <0x3d>;
                                        interrupt-parent = <&gpio30200000>;
                                        interrupts = <0x9 0x2>;
                                        adi,dsi-lanes = <0x4>;
                                        avdd-supply = <&BUCK5>;
                                        dvdd-supply = <&BUCK5>;
                                        pvdd-supply = <&BUCK5>;
                                        a2vdd-supply = <&BUCK5>;
                                        v3p3-supply = <&regulator_vddext_3v3>;
                                        v1p2-supply = <&BUCK5>;

                                        ports {
                                                #address-cells = <0x1>;
                                                #size-cells = <0x0>;

                                                port@0 {
                                                        reg = <0x0>;

                                                        endpoint_1: endpoint {
                                                                phandle = <0x4b>;
                                                                remote-endpoint = <&endpoint_1_2_3_4_5_6>;
                                                        };
                                                };

                                                port@1 {
                                                        reg = <0x1>;

                                                        endpoint_1_2_3_4_5: endpoint {
                                                                phandle = <0x63>;
                                                                remote-endpoint = <&endpoint_1_2_3_4_5_6_7>;
                                                        };
                                                };
                                        };
                                };

                                tcpc@50 {
                                        compatible = "nxp,ptn5110", "tcpci";
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&typec1grp>;
                                        reg = <0x50>;
                                        interrupt-parent = <&gpio30210000>;
                                        interrupts = <0xb 0x8>;
                                        status = "okay";

                                        connector {
                                                compatible = "usb-c-connector";
                                                label = "USB-C";
                                                power-role = "dual";
                                                data-role = "dual";
                                                try-power-role = "sink";
                                                source-pdos = <0x401912c>;
                                                sink-pdos = <0x401912c 0x9901912c>;
                                                op-sink-microwatt = <0xe4e1c0>;
                                                self-powered;

                                                port {

                                                        endpoint_1_2_3_4: endpoint {
                                                                phandle = <0x53>;
                                                                remote-endpoint = <&endpoint_1_2_3_4_5_6_7_8>;
                                                        };
                                                };
                                        };
                                };
                        };

                        i2c@30a40000 {
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;
                                compatible = "fsl,imx8mm-i2c", "fsl,imx21-i2c";
                                reg = <0x30a40000 0x10000>;
                                interrupts = <0x0 0x25 0x4>;
                                clocks = <&clock_controller30380000_1 0xa6>;
                                status = "okay";
                                clock-frequency = <0x61a80>;
                                pinctrl-names = "default";
                                pinctrl-0 = <&i2c3grp>;

                                gpio@20 {
                                        compatible = "nxp,pca6416";
                                        reg = <0x20>;
                                        gpio-controller;
                                        #gpio-cells = <0x2>;
                                        vcc-supply = <&BUCK4>;
                                };

                                camera@3c {
                                        compatible = "ovti,ov5640";
                                        reg = <0x3c>;
                                        pinctrl-names = "default";
                                        pinctrl-0 = <&cameragrp>;
                                        clocks = <&clock_controller30380000_1 0x9e>;
                                        clock-names = "xclk";
                                        assigned-clocks = <&clock_controller30380000_1 0x9e>;
                                        assigned-clock-parents = <&clock_controller30380000_1 0x2>;
                                        assigned-clock-rates = <0x16e3600>;
                                        powerdown-gpios = <&gpio30200000 0x7 0x0>;
                                        reset-gpios = <&gpio30200000 0x6 0x1>;
                                        DOVDD-supply = <&BUCK5>;
                                        AVDD-supply = <&regulator_1v8>;
                                        DVDD-supply = <&regulator_1v5>;

                                        port {

                                                endpoint_1_2: endpoint {
                                                        phandle = <0x4f>;
                                                        remote-endpoint = <&endpoint_1_2_3_4_5_6_7_8_9>;
                                                        clock-lanes = <0x0>;
                                                        data-lanes = <0x1 0x2>;
                                                };
                                        };
                                };
                        };

                        i2c@30a50000 {
                                compatible = "fsl,imx8mm-i2c", "fsl,imx21-i2c";
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;
                                reg = <0x30a50000 0x10000>;
                                interrupts = <0x0 0x26 0x4>;
                                clocks = <&clock_controller30380000_1 0xa7>;
                                status = "disabled";
                        };

                        serial@30a60000 {
                                compatible = "fsl,imx8mm-uart", "fsl,imx6q-uart";
                                reg = <0x30a60000 0x10000>;
                                interrupts = <0x0 0x1d 0x4>;
                                clocks = <&clock_controller30380000_1 0xbf>,
                                 <&clock_controller30380000_1 0xbf>;
                                clock-names = <0x69706700 0x70657200>;
                                dmas = <&dma_controller30bd0000 0x1c 0x4 0x0>,
                                 <&dma_controller30bd0000 0x1d 0x4 0x0>;
                                dma-names = "rx", "tx";
                                status = "disabled";
                        };

                        mailbox@30aa0000 {
                                compatible = "fsl,imx8mm-mu", "fsl,imx6sx-mu";
                                reg = <0x30aa0000 0x10000>;
                                interrupts = <0x0 0x58 0x4>;
                                clocks = <&clock_controller30380000_1 0xda>;
                                #mbox-cells = <0x2>;
                        };

                        mmc@30b40000 {
                                compatible = "fsl,imx8mm-usdhc", "fsl,imx7d-usdhc";
                                reg = <0x30b40000 0x10000>;
                                interrupts = <0x0 0x16 0x4>;
                                clocks = <&clock_controller30380000_1 0x5f>,
                                 <&clock_controller30380000_1 0x53>,
                                 <&clock_controller30380000_1 0xc2>;
                                clock-names = "ipg", "ahb", "per";
                                fsl,tuning-start-tap = <0x14>;
                                fsl,tuning-step = <0x2>;
                                bus-width = <0x4>;
                                status = "disabled";
                        };

                        mmc@30b50000 {
                                compatible = "fsl,imx8mm-usdhc", "fsl,imx7d-usdhc";
                                reg = <0x30b50000 0x10000>;
                                interrupts = <0x0 0x17 0x4>;
                                clocks = <&clock_controller30380000_1 0x5f>,
                                 <&clock_controller30380000_1 0x53>,
                                 <&clock_controller30380000_1 0xc3>;
                                clock-names = "ipg", "ahb", "per";
                                fsl,tuning-start-tap = <0x14>;
                                fsl,tuning-step = <0x2>;
                                bus-width = <0x4>;
                                status = "okay";
                                assigned-clocks = <&clock_controller30380000_1 0x7a>;
                                assigned-clock-rates = <0xbebc200>;
                                pinctrl-names = "default", "state_100mhz", "state_200mhz";
                                pinctrl-0 = <&usdhc2grp>,
                                 <&usdhc2grpgpiogrp>;
                                pinctrl-1 = <&usdhc2_100mhzgrp>,
                                 <&usdhc2grpgpiogrp>;
                                pinctrl-2 = <&usdhc2_200mhzgrp>,
                                 <&usdhc2grpgpiogrp>;
                                cd-gpios = <&gpio30200000 0xf 0x1>;
                                vmmc-supply = <&regulator_usdhc2>;
                        };

                        mmc@30b60000 {
                                compatible = "fsl,imx8mm-usdhc", "fsl,imx7d-usdhc";
                                reg = <0x30b60000 0x10000>;
                                interrupts = <0x0 0x18 0x4>;
                                clocks = <&clock_controller30380000_1 0x5f>,
                                 <&clock_controller30380000_1 0x53>,
                                 <&clock_controller30380000_1 0xd0>;
                                clock-names = "ipg", "ahb", "per";
                                fsl,tuning-start-tap = <0x14>;
                                fsl,tuning-step = <0x2>;
                                bus-width = <0x8>;
                                status = "okay";
                                assigned-clocks = <&clock_controller30380000_1 0xd0>;
                                assigned-clock-rates = <0x17d78400>;
                                pinctrl-names = "default", "state_100mhz", "state_200mhz";
                                pinctrl-0 = <&usdhc3grp>;
                                pinctrl-1 = <&usdhc3_100mhzgrp>;
                                pinctrl-2 = <&usdhc3_200mhzgrp>;
                                non-removable;
                        };

                        spi@30bb0000 {
                                #address-cells = <0x1>;
                                #size-cells = <0x0>;
                                compatible = "nxp,imx8mm-fspi";
                                reg = <0x30bb0000 0x10000 0x8000000 0x10000000>;
                                reg-names = "fspi_base", "fspi_mmap";
                                interrupts = <0x0 0x6b 0x4>;
                                clocks = <&clock_controller30380000_1 0xae>,
                                 <&clock_controller30380000_1 0xae>;
                                clock-names = "fspi_en", "fspi";
                                status = "okay";
                                pinctrl-names = "default";
                                pinctrl-0 = <&flexspigrp>;

                                flash@0 {
                                        reg = <0x0>;
                                        #address-cells = <0x1>;
                                        #size-cells = <0x1>;
                                        compatible = "jedec,spi-nor";
                                        spi-max-frequency = <0x4c4b400>;
                                        spi-tx-bus-width = <0x1>;
                                        spi-rx-bus-width = <0x4>;
                                };
                        };

                        dma_controller30bd0000: dma-controller@30bd0000 {
                                phandle = <0x24>;
                                compatible = "fsl,imx8mm-sdma", "fsl,imx8mq-sdma";
                                reg = <0x30bd0000 0x10000>;
                                interrupts = <0x0 0x2 0x4>;
                                clocks = <&clock_controller30380000_1 0xd3>,
                                 <&clock_controller30380000_1 0x5d>;
                                clock-names = <0x69706700 0x61686200>;
                                #dma-cells = <0x3>;
                                fsl,sdma-ram-script-name = "imx/sdma/sdma-imx7d.bin";
                        };

                        ethernet@30be0000 {
                                compatible = "fsl,imx8mm-fec", "fsl,imx8mq-fec", "fsl,imx6sx-fec";
                                reg = <0x30be0000 0x10000>;
                                interrupts = <0x0 0x76 0x4 0x0 0x77 0x4 0x0 0x78 0x4 0x0 0x79 0x4>;
                                clocks = <&clock_controller30380000_1 0xa2>,
                                 <&clock_controller30380000_1 0xa2>,
                                 <&clock_controller30380000_1 0x75>,
                                 <&clock_controller30380000_1 0x74>,
                                 <&clock_controller30380000_1 0x76>;
                                clock-names = "ipg", "ahb", "ptp", "enet_clk_ref", "enet_out";
                                assigned-clocks = <&clock_controller30380000_1 0x52>,
                                 <&clock_controller30380000_1 0x75>,
                                 <&clock_controller30380000_1 0x74>,
                                 <&clock_controller30380000_1 0x76>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x36>,
                                 <&clock_controller30380000_1 0x3a>,
                                 <&clock_controller30380000_1 0x3b>,
                                 <&clock_controller30380000_1 0x39>;
                                assigned-clock-rates = <0x0 0x5f5e100 0x7735940 0x0>;
                                fsl,num-tx-queues = <0x3>;
                                fsl,num-rx-queues = <0x3>;
                                nvmem-cells = <&mac_address90>;
                                nvmem-cell-names = "mac-address";
                                fsl,stop-mode = <&syscon30340000 0x10 0x3>;
                                status = "okay";
                                pinctrl-names = "default";
                                pinctrl-0 = <&fec1grp>;
                                phy-mode = "rgmii-id";
                                phy-handle = <&ethernet_phy0>;
                                fsl,magic-packet;

                                mdio {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;

                                        ethernet_phy0: ethernet-phy@0 {
                                                phandle = <0x45>;
                                                compatible = "ethernet-phy-ieee802.3-c22";
                                                reg = <0x0>;
                                                reset-gpios = <&gpio30230000 0x16 0x1>;
                                                reset-assert-us = <0x2710>;
                                                qca,disable-smarteee;
                                                vddio-supply = <&vddio_regulator>;

                                                vddio_regulator: vddio-regulator {
                                                        phandle = <0x47>;
                                                        regulator-min-microvolt = <0x1b7740>;
                                                        regulator-max-microvolt = <0x1b7740>;
                                                };
                                        };
                                };
                        };
                };

                bus@32c00000 {
                        compatible = "fsl,aips-bus", "simple-bus";
                        reg = <0x32c00000 0x400000>;
                        #address-cells = <0x1>;
                        #size-cells = <0x1>;
                        ranges = <0x32c00000 0x32c00000 0x400000>;

                        lcdif@32e00000 {
                                compatible = "fsl,imx8mm-lcdif", "fsl,imx6sx-lcdif";
                                reg = <0x32e00000 0x10000>;
                                clocks = <&clock_controller30380000_1 0x6b>,
                                 <&clock_controller30380000_1 0xce>,
                                 <&clock_controller30380000_1 0xcd>;
                                clock-names = "pix", "axi", "disp_axi";
                                assigned-clocks = <&clock_controller30380000_1 0x6b>,
                                 <&clock_controller30380000_1 0x55>,
                                 <&clock_controller30380000_1 0x56>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x28>,
                                 <&clock_controller30380000_1 0x41>,
                                 <&clock_controller30380000_1 0x38>;
                                assigned-clock-rates = <0x16e3600 0x1dcd6500 0xbebc200>;
                                interrupts = <0x0 0x5 0x4>;
                                power-domains = <&blk_ctrl32e28000 0x1>;
                                status = "okay";

                                port {

                                        endpoint: endpoint {
                                                phandle = <0x4a>;
                                                remote-endpoint = <&endpoint_1_2_3_4_5_6_7_8_9_10>;
                                        };
                                };
                        };

                        dsi@32e10000 {
                                compatible = "fsl,imx8mm-mipi-dsim";
                                reg = <0x32e10000 0x400>;
                                clocks = <&clock_controller30380000_1 0x8e>,
                                 <&clock_controller30380000_1 0x8f>;
                                clock-names = "bus_clk", "sclk_mipi";
                                assigned-clocks = <&clock_controller30380000_1 0x8e>,
                                 <&clock_controller30380000_1 0x8f>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x36>,
                                 <&clock_controller30380000_1 0x2>;
                                interrupts = <0x0 0x12 0x4>;
                                power-domains = <&blk_ctrl32e28000 0x2>;
                                status = "okay";
                                samsung,esc-clock-frequency = <0x989680>;

                                ports {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;

                                        port@0 {
                                                reg = <0x0>;

                                                endpoint_1_2_3_4_5_6_7_8_9_10: endpoint {
                                                        phandle = <0x49>;
                                                        remote-endpoint = <&endpoint>;
                                                };
                                        };

                                        port@1 {
                                                reg = <0x1>;

                                                endpoint_1_2_3_4_5_6: endpoint {
                                                        phandle = <0x2e>;
                                                        remote-endpoint = <&endpoint_1>;
                                                        data-lanes = <0x1 0x2 0x3 0x4>;
                                                };
                                        };
                                };
                        };

                        csi@32e20000 {
                                compatible = "fsl,imx8mm-csi", "fsl,imx7-csi";
                                reg = <0x32e20000 0x1000>;
                                interrupts = <0x0 0x10 0x4>;
                                clocks = <&clock_controller30380000_1 0xdb>;
                                clock-names = "mclk";
                                power-domains = <&blk_ctrl32e28000 0x0>;
                                status = "okay";

                                port {

                                        endpoint_1_2_3: endpoint {
                                                phandle = <0x50>;
                                                remote-endpoint = <&endpoint_1_2_3_4_5_6_7_8_9_10_11>;
                                        };
                                };
                        };

                        blk_ctrl32e28000: blk-ctrl@32e28000 {
                                phandle = <0x48>;
                                compatible = "fsl,imx8mm-disp-blk-ctrl", "syscon";
                                reg = <0x32e28000 0x100>;
                                power-domains = <&power_domain10>,
                                 <&power_domain10>,
                                 <&power_domain10>,
                                 <&power_domain11>,
                                 <&power_domain11>;
                                power-domain-names = "bus", "csi-bridge", "lcdif", "mipi-dsi", "mipi-csi";
                                clocks = <&clock_controller30380000_1 0xcd>,
                                 <&clock_controller30380000_1 0xce>,
                                 <&clock_controller30380000_1 0xdb>,
                                 <&clock_controller30380000_1 0xcd>,
                                 <&clock_controller30380000_1 0xce>,
                                 <&clock_controller30380000_1 0xcc>,
                                 <&clock_controller30380000_1 0x8e>,
                                 <&clock_controller30380000_1 0x8f>,
                                 <&clock_controller30380000_1 0x92>,
                                 <&clock_controller30380000_1 0x93>;
                                clock-names = "csi-bridge-axi", "csi-bridge-apb", "csi-bridge-core", "lcdif-axi", "lcdif-apb", "lcdif-pix", "dsi-pclk", "dsi-ref", "csi-aclk", "csi-pclk";
                                #power-domain-cells = <0x1>;
                        };

                        mipi-csi@32e30000 {
                                compatible = "fsl,imx8mm-mipi-csi2";
                                reg = <0x32e30000 0x1000>;
                                interrupts = <0x0 0x11 0x4>;
                                assigned-clocks = <&clock_controller30380000_1 0x92>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x41>;
                                clock-frequency = <0x13d92d40>;
                                clocks = <&clock_controller30380000_1 0xce>,
                                 <&clock_controller30380000_1 0xdb>,
                                 <&clock_controller30380000_1 0x93>,
                                 <&clock_controller30380000_1 0xcd>;
                                clock-names = "pclk", "wrap", "phy", "axi";
                                power-domains = <&blk_ctrl32e28000 0x3>;
                                status = "okay";

                                ports {
                                        #address-cells = <0x1>;
                                        #size-cells = <0x0>;

                                        port@0 {
                                                reg = <0x0>;

                                                endpoint_1_2_3_4_5_6_7_8_9: endpoint {
                                                        phandle = <0x38>;
                                                        remote-endpoint = <&endpoint_1_2>;
                                                        data-lanes = <0x1 0x2>;
                                                };
                                        };

                                        port@1 {
                                                reg = <0x1>;

                                                endpoint_1_2_3_4_5_6_7_8_9_10_11: endpoint {
                                                        phandle = <0x4c>;
                                                        remote-endpoint = <&endpoint_1_2_3>;
                                                };
                                        };
                                };
                        };

                        usb@32e40000 {
                                compatible = "fsl,imx8mm-usb", "fsl,imx7d-usb", "fsl,imx27-usb";
                                reg = <0x32e40000 0x200>;
                                interrupts = <0x0 0x28 0x4>;
                                clocks = <&clock_controller30380000_1 0xc0>;
                                assigned-clocks = <&clock_controller30380000_1 0x58>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x40>;
                                phys = <&usbphynop1>;
                                fsl,usbmisc = <&usbmisc32e40200 0x0>;
                                power-domains = <&power_domain0>;
                                status = "okay";
                                dr_mode = "otg";
                                hnp-disable;
                                srp-disable;
                                adp-disable;
                                usb-role-switch;
                                disable-over-current;
                                samsung,picophy-pre-emp-curr-control = <0x3>;
                                samsung,picophy-dc-vol-level-adjust = <0x7>;

                                port {

                                        endpoint_1_2_3_4_5_6_7_8: endpoint {
                                                phandle = <0x32>;
                                                remote-endpoint = <&endpoint_1_2_3_4>;
                                        };
                                };
                        };

                        usbmisc32e40200: usbmisc@32e40200 {
                                phandle = <0x52>;
                                compatible = "fsl,imx8mm-usbmisc", "fsl,imx7d-usbmisc", "fsl,imx6q-usbmisc";
                                #index-cells = <0x1>;
                                reg = <0x32e40200 0x200>;
                        };

                        usb@32e50000 {
                                compatible = "fsl,imx8mm-usb", "fsl,imx7d-usb", "fsl,imx27-usb";
                                reg = <0x32e50000 0x200>;
                                interrupts = <0x0 0x29 0x4>;
                                clocks = <&clock_controller30380000_1 0xc0>;
                                assigned-clocks = <&clock_controller30380000_1 0x58>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x40>;
                                phys = <&usbphynop2>;
                                fsl,usbmisc = <&usbmisc32e50200 0x0>;
                                power-domains = <&power_domain0>;
                                status = "disabled";
                        };

                        usbmisc32e50200: usbmisc@32e50200 {
                                phandle = <0x55>;
                                compatible = "fsl,imx8mm-usbmisc", "fsl,imx7d-usbmisc", "fsl,imx6q-usbmisc";
                                #index-cells = <0x1>;
                                reg = <0x32e50200 0x200>;
                        };

                        pcie_phy32f00000: pcie-phy@32f00000 {
                                phandle = <0x59>;
                                compatible = "fsl,imx8mm-pcie-phy";
                                reg = <0x32f00000 0x10000>;
                                clocks = <&pcie0_refclk>;
                                clock-names = "ref";
                                assigned-clocks = <&clock_controller30380000_1 0x68>;
                                assigned-clock-rates = <0x5f5e100>;
                                assigned-clock-parents = <&clock_controller30380000_1 0x3a>;
                                resets = <&reset_controller30390000 0x1a>;
                                reset-names = "pciephy";
                                #phy-cells = <0x0>;
                                status = "okay";
                                fsl,refclk-pad-mode = <0x1>;
                                fsl,tx-deemph-gen1 = <0x2d>;
                                fsl,tx-deemph-gen2 = <0xf>;
                        };
                };

                dma_controller33000000: dma-controller@33000000 {
                        phandle = <0x57>;
                        compatible = "fsl,imx7d-dma-apbh", "fsl,imx28-dma-apbh";
                        reg = <0x33000000 0x2000>;
                        interrupts = <0x0 0xc 0x4 0x0 0xc 0x4 0x0 0xc 0x4 0x0 0xc 0x4>;
                        #dma-cells = <0x1>;
                        dma-channels = <0x4>;
                        clocks = <&clock_controller30380000_1 0xde>;
                };

                nand-controller@33002000 {
                        compatible = "fsl,imx8mm-gpmi-nand", "fsl,imx7d-gpmi-nand";
                        #address-cells = <0x1>;
                        #size-cells = <0x0>;
                        reg = <0x33002000 0x2000 0x33004000 0x4000>;
                        reg-names = "gpmi-nand", "bch";
                        interrupts = <0x0 0xe 0x4>;
                        interrupt-names = "bch";
                        clocks = <&clock_controller30380000_1 0xaf>,
                         <&clock_controller30380000_1 0xde>;
                        clock-names = "gpmi_io", "gpmi_bch_apb";
                        dmas = <&dma_controller33000000 0x0>;
                        dma-names = "rx-tx";
                        status = "disabled";
                };

                pcie@33800000 {
                        compatible = "fsl,imx8mm-pcie";
                        reg = <0x33800000 0x400000 0x1ff00000 0x80000>;
                        reg-names = "dbi", "config";
                        #address-cells = <0x3>;
                        #size-cells = <0x2>;
                        device_type = "pci";
                        bus-range = <0x0 0xff>;
                        ranges = <0x81000000 0x0 0x0 0x1ff80000 0x0 0x10000 0x82000000 0x0 0x18000000 0x18000000 0x0 0x7f00000>;
                        num-lanes = <0x1>;
                        num-viewport = <0x4>;
                        interrupts = <0x0 0x7a 0x4>;
                        interrupt-names = "msi";
                        #interrupt-cells = <0x1>;
                        interrupt-map-mask = <0x0 0x0 0x0 0x7>;
                        interrupt-map = <0x0 0x0 0x0 0x1 &interrupt_controller38800000 0x0 0x7d 0x4>,
                         <0x0 0x0 0x0 0x2 &interrupt_controller38800000 0x0 0x7c 0x4>,
                         <0x0 0x0 0x0 0x3 &interrupt_controller38800000 0x0 0x7b 0x4>,
                         <0x0 0x0 0x0 0x4 &interrupt_controller38800000 0x0 0x7a 0x4>;
                        fsl,max-link-speed = <0x2>;
                        linux,pci-domain = <0x0>;
                        clocks = <&clock_controller30380000_1 0xa9>,
                         <&pcie0_refclk>,
                         <&clock_controller30380000_1 0x69>;
                        clock-names = "pcie", "pcie_bus", "pcie_aux";
                        power-domains = <&power_domain1>;
                        resets = <&reset_controller30390000 0x1c>,
                         <&reset_controller30390000 0x1d>;
                        reset-names = "apps", "turnoff";
                        phys = <&pcie_phy32f00000>;
                        phy-names = "pcie-phy";
                        status = "okay";
                        pinctrl-names = "default";
                        pinctrl-0 = <&pcie0grp>;
                        reset-gpio = <&gpio30230000 0x15 0x1>;
                        assigned-clocks = <&clock_controller30380000_1 0x69>,
                         <&clock_controller30380000_1 0x67>;
                        assigned-clock-rates = <0x989680 0xee6b280>;
                        assigned-clock-parents = <&clock_controller30380000_1 0x39>,
                         <&clock_controller30380000_1 0x3e>;
                        vpcie-supply = <&regulator_pcie>;
                        supports-clkreq;
                };

                pcie-ep@33800000 {
                        compatible = "fsl,imx8mm-pcie-ep";
                        reg = <0x33800000 0x100000 0x18000000 0x8000000 0x33900000 0x100000 0x33b00000 0x100000>;
                        reg-names = "dbi", "addr_space", "dbi2", "atu";
                        num-lanes = <0x1>;
                        interrupts = <0x0 0x7f 0x4>;
                        interrupt-names = "dma";
                        fsl,max-link-speed = <0x2>;
                        clocks = <&clock_controller30380000_1 0xa9>,
                         <&pcie0_refclk>,
                         <&clock_controller30380000_1 0x69>;
                        clock-names = "pcie", "pcie_bus", "pcie_aux";
                        power-domains = <&power_domain1>;
                        resets = <&reset_controller30390000 0x1c>,
                         <&reset_controller30390000 0x1d>;
                        reset-names = "apps", "turnoff";
                        phys = <&pcie_phy32f00000>;
                        phy-names = "pcie-phy";
                        num-ib-windows = <0x4>;
                        num-ob-windows = <0x4>;
                        status = "disabled";
                        pinctrl-names = "default";
                        pinctrl-0 = <&pcie0grp>;
                        assigned-clocks = <&clock_controller30380000_1 0x69>,
                         <&clock_controller30380000_1 0x67>;
                        assigned-clock-rates = <0x989680 0xee6b280>;
                        assigned-clock-parents = <&clock_controller30380000_1 0x39>,
                         <&clock_controller30380000_1 0x3e>;
                };

                gpu@38000000 {
                        compatible = "vivante,gc";
                        reg = <0x38000000 0x8000>;
                        interrupts = <0x0 0x3 0x4>;
                        clocks = <&clock_controller30380000_1 0x5a>,
                         <&clock_controller30380000_1 0xc8>,
                         <&clock_controller30380000_1 0xc1>,
                         <&clock_controller30380000_1 0xc1>;
                        clock-names = "reg", "bus", "core", "shader";
                        assigned-clocks = <&clock_controller30380000_1 0xf8>,
                         <&clock_controller30380000_1 0x2a>;
                        assigned-clock-parents = <&clock_controller30380000_1 0x2a>;
                        assigned-clock-rates = <0x0 0x2faf0800>;
                        power-domains = <&power_domain5>;
                };

                gpu@38008000 {
                        compatible = "vivante,gc";
                        reg = <0x38008000 0x8000>;
                        interrupts = <0x0 0x19 0x4>;
                        clocks = <&clock_controller30380000_1 0x5a>,
                         <&clock_controller30380000_1 0xc8>,
                         <&clock_controller30380000_1 0xd9>;
                        clock-names = "reg", "bus", "core";
                        assigned-clocks = <&clock_controller30380000_1 0xf9>,
                         <&clock_controller30380000_1 0x2a>;
                        assigned-clock-parents = <&clock_controller30380000_1 0x2a>;
                        assigned-clock-rates = <0x0 0x2faf0800>;
                        power-domains = <&power_domain5>;
                };

                video-codec@38300000 {
                        compatible = "nxp,imx8mm-vpu-g1";
                        reg = <0x38300000 0x10000>;
                        interrupts = <0x0 0x7 0x4>;
                        clocks = <&clock_controller30380000_1 0xc7>;
                        power-domains = <&blk_ctrl38330000 0x0>;
                };

                video-codec@38310000 {
                        compatible = "nxp,imx8mq-vpu-g2";
                        reg = <0x38310000 0x10000>;
                        interrupts = <0x0 0x8 0x4>;
                        clocks = <&clock_controller30380000_1 0xca>;
                        power-domains = <&blk_ctrl38330000 0x1>;
                };

                blk_ctrl38330000: blk-ctrl@38330000 {
                        phandle = <0x5d>;
                        compatible = "fsl,imx8mm-vpu-blk-ctrl", "syscon";
                        reg = <0x38330000 0x100>;
                        power-domains = <&power_domain6>,
                         <&power_domain7>,
                         <&power_domain8>,
                         <&power_domain9>;
                        power-domain-names = "bus", "g1", "g2", "h1";
                        clocks = <&clock_controller30380000_1 0xc7>,
                         <&clock_controller30380000_1 0xca>,
                         <&clock_controller30380000_1 0xc9>;
                        clock-names = "g1", "g2", "h1";
                        assigned-clocks = <&clock_controller30380000_1 0x63>,
                         <&clock_controller30380000_1 0x64>;
                        assigned-clock-parents = <&clock_controller30380000_1 0x2b>,
                         <&clock_controller30380000_1 0x2b>;
                        assigned-clock-rates = <0x23c34600 0x23c34600>;
                        #power-domain-cells = <0x1>;
                };

                interrupt_controller38800000: interrupt-controller@38800000 {
                        phandle = <0x1>;
                        compatible = "arm,gic-v3";
                        reg = <0x38800000 0x10000 0x38880000 0xc0000>;
                        #address-cells = <0x0>;
                        #interrupt-cells = <0x3>;
                        interrupt-controller;
                        interrupts = <0x1 0x9 0x4>;
                };

                memory-controller@3d400000 {
                        compatible = "fsl,imx8mm-ddrc", "fsl,imx8m-ddrc";
                        reg = <0x3d400000 0x400000>;
                        clock-names = "core", "pll", "alt", "apb";
                        clocks = <&clock_controller30380000_1 0xdc>,
                         <&clock_controller30380000_1 0x15>,
                         <&clock_controller30380000_1 0x61>,
                         <&clock_controller30380000_1 0x62>;
                        operating-points-v2 = <&opp_table_1>;

                        opp_table_1: opp-table {
                                phandle = <0x62>;
                                compatible = "operating-points-v2";

                                opp-25000000 {
                                        opp-hz = /bits/ 64 <0x17d7840>;
                                };

                                opp-100000000 {
                                        opp-hz = /bits/ 64 <0x5f5e100>;
                                };

                                opp-750000000 {
                                        opp-hz = /bits/ 64 <0x2cb41780>;
                                };
                        };
                };

                ddr-pmu@3d800000 {
                        compatible = "fsl,imx8mm-ddr-pmu", "fsl,imx8m-ddr-pmu";
                        reg = <0x3d800000 0x400000>;
                        interrupts = <0x0 0x62 0x4>;
                };
        };

        chosen {
                stdout-path = "/soc@0/bus@30800000/spba-bus@30800000/serial@30890000";
        };

        memory@40000000 {
                device_type = "memory";
                reg = <0x0 0x40000000 0x0 0x80000000>;
        };

        hdmi-connector {
                compatible = "hdmi-connector";
                label = "hdmi";
                type = "a";

                port {

                        endpoint_1_2_3_4_5_6_7: endpoint {
                                phandle = <0x2f>;
                                remote-endpoint = <&endpoint_1_2_3_4_5>;
                        };
                };
        };

        leds {
                compatible = "gpio-leds";
                pinctrl-names = "default";
                pinctrl-0 = <&gpioledgrp>;

                status {
                        label = "status";
                        gpios = <&gpio30220000 0x10 0x0>;
                        default-state = "on";
                };
        };

        pcie0_refclk: pcie0-refclk {
                phandle = <0x56>;
                compatible = "fixed-clock";
                #clock-cells = <0x0>;
                clock-frequency = <0x5f5e100>;
        };

        regulator_pcie: regulator-pcie {
                phandle = <0x5b>;
                compatible = "regulator-fixed";
                pinctrl-names = "default";
                pinctrl-0 = <&pcie0reggrp>;
                regulator-name = "MPCIE_3V3";
                regulator-min-microvolt = <0x325aa0>;
                regulator-max-microvolt = <0x325aa0>;
                gpio = <&gpio30200000 0x5 0x0>;
                enable-active-high;
        };

        regulator_usdhc2: regulator-usdhc2 {
                phandle = <0x3d>;
                compatible = "regulator-fixed";
                pinctrl-names = "default";
                pinctrl-0 = <&regusdhc2vmmcgrp>;
                regulator-name = "VSD_3V3";
                regulator-min-microvolt = <0x325aa0>;
                regulator-max-microvolt = <0x325aa0>;
                gpio = <&gpio30210000 0x13 0x0>;
                off-on-delay-us = <0x4e20>;
                enable-active-high;
        };

        regulator_1v5: regulator-1v5 {
                phandle = <0x37>;
                compatible = "regulator-fixed";
                regulator-name = "VDD_1V5";
                regulator-min-microvolt = <0x16e360>;
                regulator-max-microvolt = <0x16e360>;
        };

        regulator_1v8: regulator-1v8 {
                phandle = <0x36>;
                compatible = "regulator-fixed";
                regulator-name = "VDD_1V8";
                regulator-min-microvolt = <0x1b7740>;
                regulator-max-microvolt = <0x1b7740>;
        };

        regulator_vddext_3v3: regulator-vddext-3v3 {
                phandle = <0x2d>;
                compatible = "regulator-fixed";
                regulator-name = "VDDEXT_3V3";
                regulator-min-microvolt = <0x325aa0>;
                regulator-max-microvolt = <0x325aa0>;
        };

        backlight {
                compatible = "pwm-backlight";
                pwms = <0x68 0x0 0x4c4b40 0x0>;
                brightness-levels = <0x0 0xff>;
                num-interpolated-steps = <0xff>;
                default-brightness-level = <0xfa>;
        };

        ir-receiver {
                compatible = "gpio-ir-receiver";
                gpios = <&gpio30200000 0xd 0x1>;
                pinctrl-names = "default";
                pinctrl-0 = <&irgrp>;
                linux,autosuspend-period = <0x7d>;
        };

        audio_codec_bt_sco: audio-codec-bt-sco {
                phandle = <0x6e>;
                compatible = "linux,bt-sco";
                #sound-dai-cells = <0x1>;
        };

        audio_codec: audio-codec {
                phandle = <0x71>;
                #sound-dai-cells = <0x0>;
                compatible = "wlf,wm8524";
                pinctrl-names = "default";
                pinctrl-0 = <&gpiowlfgrp>;
                wlf,mute-gpios = <0x6b 0x15 0x1>;
        };

        sound-bt-sco {
                compatible = "simple-audio-card";
                simple-audio-card,name = "bt-sco-audio";
                simple-audio-card,format = "dsp_a";
                simple-audio-card,bitclock-inversion;
                simple-audio-card,frame-master = <&simple_audio_card_cpu>;
                simple-audio-card,bitclock-master = <&simple_audio_card_cpu>;

                simple_audio_card_cpu: simple-audio-card,cpu {
                        phandle = <0x6c>;
                        sound-dai = <&sai30020000>;
                        dai-tdm-slot-num = <0x2>;
                        dai-tdm-slot-width = <0x10>;
                };

                simple-audio-card,codec {
                        sound-dai = <&audio_codec_bt_sco>,
                         <&interrupt_controller38800000>;
                };
        };

        sound-wm8524 {
                compatible = "simple-audio-card";
                simple-audio-card,name = "wm8524-audio";
                simple-audio-card,format = "i2s";
                simple-audio-card,frame-master = <&simple_audio_card_cpu_1>;
                simple-audio-card,bitclock-master = <&simple_audio_card_cpu_1>;
                simple-audio-card,mclk-fs = <0x100>;
                simple-audio-card,widgets = "Line", "Left Line Out Jack", "Line", "Right Line Out Jack";
                simple-audio-card,routing = "Left Line Out Jack", "LINEVOUTL", "Right Line Out Jack", "LINEVOUTR";

                simple_audio_card_cpu_1: simple-audio-card,cpu {
                        phandle = <0x6f>;
                        sound-dai = <&sai30030000>;
                        dai-tdm-slot-num = <0x2>;
                        dai-tdm-slot-width = <0x20>;
                        system-clock-direction-out;
                };

                simple-audio-card,codec {
                        sound-dai = <&audio_codec>;
                };
        };

        sound-micfil {
                compatible = "fsl,imx-audio-card";
                model = "micfil-audio";

                pri-dai-link {
                        link-name = "micfil hifi";
                        format = "i2s";

                        cpu {
                                sound-dai = <&audio_controller30080000>;
                        };
                };
        };

        spdif_out: spdif-out {
                phandle = <0x74>;
                compatible = "linux,spdif-dit";
                #sound-dai-cells = <0x0>;
        };

        spdif_in: spdif-in {
                phandle = <0x75>;
                compatible = "linux,spdif-dir";
                #sound-dai-cells = <0x0>;
        };

        sound-spdif {
                compatible = "fsl,imx-audio-spdif";
                model = "imx-spdif";
                audio-cpu = <&spdif30090000>;
                audio-codec = <&spdif_out>,
                 <&spdif_in>;
        };

        cpus_m4: cpus-m4@0 {
                #address-cells = <0x1>;
                #size-cells = <0x0>;
                compatible = "cpus,cluster";
                lopper-source = "zephyr";

                cpu@0 {
                        device_type = "cpu";
                        compatible = "arm,cortex-m4";
                        reg = <0x0>;
                        lopper-source = "zephyr";
                };
        };

        memory@20000000 {
                device_type = "memory";
                reg = <0x0 0x20000000 0x0 0x20000>;
                compatible = "nxp,imx-dtcm";
                lopper-source = "zephyr";
        };

        memory@20200000 {
                reg = <0x0 0x20200000 0x0 0x40000>;
                device_type = "memory";
                compatible = "nxp,imx-sys-bus";
                lopper-source = "zephyr";
        };

        memory@20180000 {
                reg = <0x0 0x20180000 0x0 0x8000>;
                device_type = "memory";
                compatible = "nxp,imx-sys-bus";
                lopper-source = "zephyr";
        };

        reserved-memory {
                #address-cells = <0x2>;
                #size-cells = <0x2>;
                ranges;

                m4_reserved@80000000 {
                        reg = <0x0 0x80000000 0x0 0x100000>;
                        no-map;
                        lopper-source = "domain";
                };

                rpmsg_shmem@b8000000 {
                        reg = <0x0 0xb8000000 0x0 0x400000>;
                        no-map;
                        lopper-source = "domain";
                };
        };

        non_linux_soc: non_linux_soc {
                compatible = "simple-bus";
                #address-cells = <0x1>;
                #size-cells = <0x1>;
                lopper-source = "non-linux";

                interrupt_controllere000e100: interrupt-controller@e000e100 {
                        #address-cells = <0x1>;
                        compatible = "arm,v7m-nvic";
                        reg = <0xe000e100 0xc00>;
                        interrupt-controller;
                        #interrupt-cells = <0x2>;
                        arm,num-irq-priority-bits = <0x4>;
                        lopper-source = "zephyr";
                };

                timer@e000e010 {
                        compatible = "arm,armv7m-systick";
                        reg = <0xe000e010 0x10>;
                        lopper-source = "zephyr";
                };

                code@1ffe0000 {
                        compatible = "nxp,imx-itcm";
                        reg = <0x1ffe0000 0x20000>;
                        lopper-source = "zephyr";
                };

                code@900000 {
                        compatible = "nxp,imx-code-bus";
                        reg = <0x900000 0x40000>;
                        lopper-source = "zephyr";
                };

                code@180000 {
                        compatible = "nxp,imx-code-bus";
                        reg = <0x180000 0x8000>;
                        lopper-source = "zephyr";
                };

                mailbox@30ab0000 {
                        compatible = "nxp,imx-mu";
                        reg = <0x30ab0000 0x10000>;
                        interrupts = <0x61 0x0>;
                        rdc = <0xf>;
                        status = "disabled";
                        lopper-source = "zephyr";
                };
        };
};
